# ──────────────────────────────────────────────────────────────────────
#  Environment Variables — mobility-analytics
#  Copy this file to .env before running the project.
#  First launch: set HIVE_IS_RESUME=false
#  Later restarts: set HIVE_IS_RESUME=true
# ──────────────────────────────────────────────────────────────────────

# ── PostgreSQL / Hive Metastore backend ───────────────────────────────
POSTGRES_DB=metastore
POSTGRES_USER=hive
POSTGRES_PASSWORD=hive

# ── IMPORTANT: Hive resume flag ───────────────────────────────────────
# First launch:   HIVE_IS_RESUME=false   (initialises metastore schema)
# Every restart:  HIVE_IS_RESUME=true    (skips re-initialisation)
HIVE_IS_RESUME=false

# ── Spark cluster ─────────────────────────────────────────────────────
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g
SHUFFLE_PARTITIONS=4
SPARK_LOG_LEVEL=WARN

# ── Kafka ─────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=traffic-topic
KAFKA_PARTITIONS=3
MAX_OFFSETS_PER_TRIGGER=2000

# ── Hive Metastore ────────────────────────────────────────────────────
HIVE_METASTORE_URI=thrift://hive-metastore:9083

# ── Storage ───────────────────────────────────────────────────────────
WAREHOUSE_PATH=/opt/spark/warehouse

# ── Trigger intervals ─────────────────────────────────────────────────
BRONZE_TRIGGER_INTERVAL=10 seconds
SILVER_TRIGGER_INTERVAL=15 seconds
GOLD_TRIGGER_INTERVAL=30 seconds

# ── DQ thresholds (Silver layer) ──────────────────────────────────────
SPEED_MIN_KMH=0
SPEED_MAX_KMH=160
LATE_EVENT_MINUTES=20
FUTURE_EVENT_MINUTES=10
WATERMARK_MINUTES=15

# ── Host-side producer (runs outside Docker) ─────────────────────────
PRODUCER_BOOTSTRAP_SERVERS=localhost:29092